# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.
.env.sentry-build-plugin

# dependencies
node_modules
/.pnp
.pnp.js

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# local env files
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# playwright testing temp files
/admin*_auth.json
/worker*_auth.json
/user_auth.json
/build-archive.log
/test-results
/output/

# generated clients ... in particular, the API to the Onyx backend itself!
/src/lib/generated
.jest-cache

# storybook
storybook-static

# Core dumps from crashed dev processes. Must be ignored here (not just in a
# global gitignore) so Tailwind v4's content scanner skips them — scanning a
# binary core dump extracts garbage class candidates and corrupts generated CSS.
core.[0-9]*
